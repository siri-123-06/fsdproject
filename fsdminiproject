<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AP Government Schemes</title>

<style>
body {
    font-family: Arial;
    background: #f4f4f4;
    margin: 0;
}

.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #004aad;
    color: white;
    padding: 20px;
}

.header img {
    width: 120px;
    border-radius: 10px;
}

.container {
    padding: 20px;
    text-align: center;
}

select, button {
    padding: 10px;
    margin: 10px;
    width: 200px;
}

button {
    background: green;
    color: white;
    border: none;
    cursor: pointer;
}

.scheme {
    display: flex;
    background: white;
    margin: 15px;
    padding: 15px;
    border-radius: 10px;
    align-items: center;
}

.scheme img {
    width: 120px;
    margin-left: 20px;
    border-radius: 10px;
}

.scheme-details {
    flex: 1;
}

/* ✅ NEW CHANGE */
.scheme-details h3 {
    font-size: 26px;
    font-weight: bold;
    color: #004aad;
    margin-bottom: 8px;
    text-transform: uppercase;
}
</style>

</head>
<body>

<div class="header">
    <h1>AP Government Schemes</h1>
    <img src="first.jpeg">
</div>

<div class="container">

<select id="age">
    <option value="">Select Age</option>
    <option value="school">1-15 (Student)</option>
    <option value="ug">15-20 (Undergraduate)</option>
    <option value="adult">21-60</option>
    <option value="senior">60+</option>
</select>

<select id="gender">
    <option value="">Select Gender</option>
    <option value="female">Female</option>
    <option value="male">Male</option>
</select>

<select id="qualification">
    <option value="">Qualification</option>
    <option value="school">School</option>
    <option value="graduate">Graduate</option>
    <option value="farmer">Farmer</option>
    <option value="unemployed">Unemployed</option>
    <option value="Housewife">Housewife</option>
    <option value="undergraduate">Undergraduate</option>
</select>

<br>
<button onclick="showSchemes()">Find Schemes</button>
</div>

<div id="output"></div>

<div id="imageModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); justify-content:center; align-items:center;">
    <span onclick="closeImage()" style="position:absolute; top:20px; right:40px; font-size:40px; color:white; cursor:pointer;">&times;</span>
    <img id="modalImg" style="max-width:80%; max-height:80%; border-radius:10px;">
</div>

<script>

const schemes = [

{
name:"Thalliki Vandanam",
about:"Provides ₹15,000 yearly to mothers for children studying in classes 1–10 (age 1–15).",
category:["school"],
img:"tallikivandan.jpeg",
link:"https://en.vikaspedia.in/viewcontent/schemesall/state-specific-schemes/welfare-schemes-of-andhra-pradesh/thalliki-vandanam-scheme"
},

{
name:"Vidya Deevena",
about:"Full fee reimbursement for undergraduate and college students (age 15–20).",
category:["ug"],
img:"feereimb.jpeg",
link:"https://jnanabhumi.ap.gov.in/"

},

{
name:"NTR Bharosa Pension",
about:"₹4,000 for elderly, ₹6,000 for disabled.",
category:["senior"],
img:"pension.jpeg",
link:"https://sspensions.ap.gov.in/SSP"
},

{
name:"Chandranna Bima",
about:"Insurance for unorganized workers.",
category:["adult"],
img:"bhima.jpeg",
link:"https://chandrannabima.ap.gov.in/new/AboutScheme.aspx"
},

{
name:"d+Krishi",
about:"Digital platform for farmers.",
category:["farmer"],
img:"dkrishi.jpeg",
link:"https://eseed.ap.gov.in/eseedLogin/"
},

{
name:"Paddy Procurement",
about:"Ensures MSP for farmers.",
category:["farmer"],
img:"paddy.jpeg",
link:"http://www.apscscl.in/marketing.php"
},

{
name:"Stree Shakti",
about:"Empowers women via SHGs.",
category:["female"],
img:"streeshakthi.jpeg",
link:"https://en.vikaspedia.in/viewcontent/schemesall/state-specific-schemes/welfare-schemes-of-andhra-pradesh/stree-shakti-scheme?lgn=en"
},

{
name:"Jal Jeevan Mission",
about:"Provides drinking water to rural homes.",
category:["adult"],
img:"jaljeevan.jpeg",
link:"https://jaljeevanmission.gov.in/"
},

{
name:"Vaidya Seva",
about:"Health insurance scheme.",
category:["adult"],
img:"arogya.jpeg",
link:"https://drntrvaidyaseva.ap.gov.in/asri"
},

{
name:"AP Housing",
about:"Housing support for poor.",
category:["adult"],
img:"housing.jpeg",
link:"https://housing.ap.gov.in/"
},

{
name:"Videshi Vidya Deevena",
about:"Support for studying abroad.",
category:["graduate"],
img:"foreign.jpeg",
link:"https://services.india.gov.in/service/detail/jagananna-videshi-vidya-deevena-scheme-andhra-pradesh-1"
},

{
name:"Nirudyoga Bruthi",
about:"Unemployment allowance.",
category:["graduate"],
img:"unemploy.jpeg",
link:"https://www.govtschemes.in/ap-nirudyoga-bruthi-scheme"
}

];

function showSchemes() {
    const age = document.getElementById("age").value;
    const gender = document.getElementById("gender").value;
    const qual = document.getElementById("qualification").value;

    let output = "";
    let count = 1;

    schemes.forEach(s => {
        if(
            s.category.includes(age) ||
            s.category.includes(gender) ||
            s.category.includes(qual)
        ){
            output += `
<div class="scheme">
    <div class="scheme-details">
        <h3>${count}. ${s.name}</h3>
        <p><b>About:</b> ${s.about}</p>

        <a href="${s.link}" target="_blank">
            <button>View Details</button>
        </a>

    </div>
    <img 
    src="${s.img ? s.img : 'https://via.placeholder.com/120'}" 
    onclick="openImage(this.src)" 
    style="cursor:pointer;">
</div>
`;
            count++;
        }
    });

    document.getElementById("output").innerHTML = output || "<p>No schemes found</p>";
}

function openImage(src) {
    document.getElementById("imageModal").style.display = "flex";
    document.getElementById("modalImg").src = src;
}

function closeImage() {
    document.getElementById("imageModal").style.display = "none";
}

</script>

</body>
</html>
